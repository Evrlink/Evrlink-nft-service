{
  "name": "evrlink-nft-service",
  "version": "1.0.0",
  "description": "A Hardhat-based smart contract service for minting greeting card NFTs on Base network",
  "main": "index.js",
  "scripts": {
    "test": "npx hardhat test",
    "test:paymaster": "npx hardhat test test/GreetingCardPaymaster.test.ts",
    "compile": "npx hardhat compile",
    "deploy:base-sepolia": "npx hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:base": "npx hardhat run scripts/deploy.ts --network base",
    "deploy:paymaster:base-sepolia": "npx hardhat run scripts/deploy-paymaster.ts --network baseSepolia",
    "deploy:paymaster:base": "npx hardhat run scripts/deploy-paymaster.ts --network base",
    "mint": "npx hardhat run scripts/mint.ts",
    "verify": "npx hardhat run scripts/verify.ts"
  },
  "keywords": [
    "nft",
    "ethereum",
    "base",
    "hardhat",
    "solidity"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.1",
    "@types/node": "^22.18.1",
    "chai": "^4.5.0",
    "dotenv": "^17.2.2",
    "ethers": "^6.15.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^2.26.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.8"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0"
  }
}
